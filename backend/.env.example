# ─────────────────────────────────────────────
#  Lyric Video Studio — Backend Environment
# ─────────────────────────────────────────────
#  cp backend/.env.example backend/.env

# ── Application ──────────────────────────────
APP_ENV=production
UPLOAD_DIR=uploads
OUTPUT_DIR=output
MAX_UPLOAD_SIZE_MB=500

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=https://your-domain.com

# ── Auth ─────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=168

# Admin email — password is auto-generated on first startup and printed to logs
ADMIN_EMAIL=your-email@example.com

# ── Frontend URL (used in invite email links) ─
FRONTEND_URL=https://your-domain.com

# ── Email / SMTP (optional) ──────────────────
# Without SMTP, invite links are printed to server logs only.
# Gmail: enable 2FA → generate App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
