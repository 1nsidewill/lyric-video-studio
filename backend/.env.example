# ─────────────────────────────────────────────
#  Lyric Video Studio — Backend Environment
# ─────────────────────────────────────────────
#  Copy this file to .env and fill in values.
#  cp .env.example .env

# ── Application ──────────────────────────────
# Runtime mode: development | production
APP_ENV=development

# ── Storage ──────────────────────────────────
# Directory for uploaded project files (audio, artwork, lyrics)
# Relative to the backend/ folder, or use an absolute path
UPLOAD_DIR=uploads

# Directory where rendered MP4 files are saved
OUTPUT_DIR=output

# Maximum allowed upload file size (in megabytes)
MAX_UPLOAD_SIZE_MB=100

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Dev default: Vite dev server
# Prod example: https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS=http://localhost:5173
